# Local tool state / bindings — not for a shared repo
.muni/
.grok/
.claude/settings.local.json

# Secrets — never commit keys
*.key
*_key
*_key.txt
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Run outputs / scratch
runs/
runs/**/rank*.pdb          # loose per-pose PDBs — keep the repo lean (use top_hits.sdf.gz)
slurm_work/                # SLURM oracle scratch (ligands, sbatch, poses, scores)
synthon_ts/slurm_work/
*.pse
synthon_ts_*_hits.json
