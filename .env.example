# Copy this file to `.env` and fill in your keys.
#   cp .env.example .env      # then edit .env
# The real `.env` is gitignored — never commit your keys.
#
# Load it one of two ways:
#   (a) export into the shell:   set -a; source .env; set +a
#   (b) auto-load: `pip install python-dotenv` and synthon_ts.run picks up .env automatically.

# onepot direct REST API — analog retrieval + sample_space seeding.
# From your onepot account (https://onepot.ai). Header: X-API-Key.
ONEPOT_API_KEY=your-onepot-api-key-here

# Rowan API key — docking backend (single + batch) and pose export.
# From your Rowan account (https://rowansci.com). Needed for --backend direct
# and always for pose export (muni batch docking returns no poses).
ROWAN_API_KEY=your-rowan-api-key-here
